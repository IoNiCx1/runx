{
  "name": "runx",
  "displayName": "RunX",
  "description": "Nexa language support and runner",
  "version": "0.0.1",
  "publisher": "IoNiCx1",

  "repository": {
    "type": "git",
    "url": "https://github.com/IoNiCx1/runx"
  },

  "homepage": "https://github.com/IoNiCx1/runx",

  "bugs": {
    "url": "https://github.com/IoNiCx1/runx/issues"
  },

  "engines": {
    "vscode": "^1.80.0"
  },

  "categories": [
    "Programming Languages"
  ],

  "activationEvents": [
    "onLanguage:nexa",
    "onCommand:runx.runFile"
  ],

  "main": "./extension.js",

  "files": [
    "extension.js",
    "bin/**",
    "language-configuration.json",
    "README.md"
  ],

  "contributes": {
    "languages": [
      {
        "id": "nexa",
        "aliases": ["Nexa", "nexa"],
        "extensions": [".nx"],
        "configuration": "./language-configuration.json"
      }
    ],

    "commands": [
      {
        "command": "runx.runFile",
        "title": "Run Nexa File"
      }
    ],

    "menus": {
      "editor/title": [
        {
          "command": "runx.runFile",
          "when": "editorLangId == nexa",
          "group": "navigation"
        }
      ]
    }
  },

  "scripts": {},

  "devDependencies": {},

  "dependencies": {}
}