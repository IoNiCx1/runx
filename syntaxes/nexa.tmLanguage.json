{
  "name": "Nexa",
  "scopeName": "source.nexa",
  "fileTypes": ["nx"],
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#keywords" },
    { "include": "#types" },
    { "include": "#ml_functions" },
    { "include": "#csv_functions" },
    { "include": "#builtin_functions" },
    { "include": "#numbers" },
    { "include": "#operators" },
    { "include": "#identifiers" }
  ],
  "repository": {

    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.nexa",
          "match": "//.*$"
        }
      ]
    },

    "strings": {
      "name": "string.quoted.double.nexa",
      "begin": "\"",
      "end": "\"",
      "patterns": [
        {
          "name": "constant.character.escape.nexa",
          "match": "\\\\[ntr\\\\\"0]"
        }
      ]
    },

    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.nexa",
          "match": "\\b(if|else|loop|return|while|break|continue)\\b"
        },
        {
          "name": "keyword.declaration.nexa",
          "match": "\\b(fn|struct|constructor|self)\\b"
        },
        {
          "name": "keyword.import.nexa",
          "match": "\\b(imp)\\b"
        },
        {
          "name": "constant.language.nexa",
          "match": "\\b(true|false)\\b"
        },
        {
          "name": "keyword.operator.nexa",
          "match": "\\b(print)\\b"
        }
      ]
    },

    "types": {
      "name": "storage.type.nexa",
      "match": "\\b(int|double|string|bool|tensor|void)\\b"
    },

    "ml_functions": {
      "name": "support.function.ml.nexa",
      "match": "\\b(LoRe|LoRe2|fit|predict|predict_proba|accuracy|confusion|weights|bias|normalize|shuffle|train_split|test_split|hstack)\\b(?=\\s*\\()"
    },

    "csv_functions": {
      "name": "support.function.csv.nexa",
      "match": "\\b(read_csv|write_csv|csv_rows|csv_cols|csv_get|csv_set|csv_row|csv_col|csv_slice)\\b(?=\\s*\\()"
    },

    "builtin_functions": {
      "name": "support.function.builtin.nexa",
      "match": "\\b(zeros|ones|sum|mean|max|min|reshape|shape|matmul|get_value)\\b(?=\\s*\\()"
    },

    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.float.nexa",
          "match": "\\b[0-9]+\\.[0-9]*\\b"
        },
        {
          "name": "constant.numeric.integer.nexa",
          "match": "\\b[0-9]+\\b"
        }
      ]
    },

    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.comparison.nexa",
          "match": "(==|!=|<=|>=|<|>)"
        },
        {
          "name": "keyword.operator.assignment.nexa",
          "match": "="
        },
        {
          "name": "keyword.operator.arithmetic.nexa",
          "match": "(\\+|-|\\*|/)"
        },
        {
          "name": "keyword.operator.arrow.nexa",
          "match": "->"
        }
      ]
    },

    "identifiers": {
      "patterns": [
        {
          "name": "entity.name.function.nexa",
          "match": "\\b([a-zA-Z_][a-zA-Z0-9_]*)\\s*(?=\\()"
        },
        {
          "name": "variable.other.nexa",
          "match": "\\b[a-zA-Z_][a-zA-Z0-9_]*\\b"
        }
      ]
    }
  }
}
